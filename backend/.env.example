# Copy to .env locally. Railway: set variables in the project dashboard.

# Required on Railway / production Postgres (internal URL recommended):
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Local SQLite examples:
# DATABASE_URL=sqlite:///./app.db

# SECURITY: generate with `openssl rand -hex 32`
SECRET_KEY=

# production | development (Railway sets RAILWAY_ENVIRONMENT)
ENVIRONMENT=development

# Vercel (or any browser) origin for CORS allow_origins — required on Railway / production:
# FRONTEND_URL=https://your-app.vercel.app
# Optional extra origins (comma-separated), merged with FRONTEND_URL, e.g. local dev:
# CORS_ORIGINS=http://localhost:5173

# Optional: skip create_all when you manage schema with Alembic
# SKIP_DB_CREATE_ALL=false

# Optional Celery (image upload tasks need a worker + broker on Railway)
# REDIS_URL=redis://default:password@redis.railway.internal:6379
